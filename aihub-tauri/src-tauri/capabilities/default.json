{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "shell-capability",
  "description": "Permissions for the shell (sidebar) webview",
  "webviews": ["shell"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:webview:default",
    "core:window:default",
    "store:default",
    "opener:default"
  ]
}
